PROJECT_NAME="Quan Ly Du An API"
API_V1_STR=/api/v1

# CORS origins (JSON list). Ví dụ cho frontend dev:
BACKEND_CORS_ORIGINS=["http://localhost:3002"]

# Database (mặc định dùng SQLite cho dev)
SQLALCHEMY_DATABASE_URI=sqlite:///./sql_app.db

# Ví dụ PostgreSQL (bỏ comment và chỉnh lại cho production):
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://user:password@localhost:5432/quan_ly_tien_do

# Auth / JWT - BẮT BUỘC đổi trên production
SECRET_KEY=change-me-in-production-use-env-file
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Gemini API (tùy chọn, dùng cho tính năng AI)
GEMINI_API_KEY=

# SMTP Email (dùng cho gửi mail reset mật khẩu, thông báo, ...)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

